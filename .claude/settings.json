{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Skill",
      "Bash(pnpm vitest run:*)",
      "Bash(pnpm --filter @primitiv/react vitest run:*)",
      "Bash(pnpm --filter @primitiv/react qa:*)",
      "Bash(pnpm --filter @primitiv/react qa:units)",
      "Bash(pnpm --filter @primitiv/react qa:units:watch)",
      "Bash(pnpm --filter \"harmoni-*\" exec cargo test:*)",
      "Bash(cargo test --workspace:*)",
      "Bash(cargo test --package:*)",
      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(pnpm run build:wasm)",
      "Bash(pnpm install)",
      "Bash(pnpm install --frozen-lockfile)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(git branch:*)",
      "Bash(git branch --show-current)",
      "Bash(git add packages/:*)",
      "Bash(git add crates/:*)",
      "Bash(git add apps/:*)",
      "Bash(git add CLAUDE.md)",
      "Bash(git add .claude/:*)",
      "Bash(git add .gitignore)",
      "Bash(git commit -m:*)",
      "Bash(git commit -F:*)",
      "Bash(git push:*)",
      "Bash(git push -u origin:*)",
      "Bash(ls:*)",
      "Bash(cat /home/user/primitiv/packages/react/:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find packages/:*)",
      "Bash(find crates/:*)",
      "Bash(find apps/:*)",
      "Bash(wc:*)",
      "mcp__github__pull_request_read",
      "mcp__github__list_pull_requests",
      "mcp__github__list_issues",
      "mcp__github__issue_read",
      "mcp__github__list_branches",
      "mcp__github__get_commit",
      "mcp__github__list_commits",
      "mcp__github__get_file_contents",
      "mcp__github__search_code",
      "mcp__github__search_pull_requests",
      "mcp__github__get_me"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "mcp__github__create_repository",
      "mcp__github__fork_repository",
      "mcp__github__delete_file"
    ]
  },
  "env": {
    "PRIMITIV_REACT_PKG": "@primitiv/react",
    "CLAUDE_PROJECT_NAME": "primitiv"
  }
}
