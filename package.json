{
  "name": "primitiv",
  "private": true,
  "scripts": {
    "build:wasm": "pnpm --filter primitiv-wasm exec wasm-pack build --target web",
    "build:core": "pnpm --filter primitiv-core exec cargo build",
    "test:rust": "pnpm --filter \"primitiv-*\" exec cargo test",
    "test:e2e": "pnpm --filter web exec playwright test",
    "test:full": "pnpm test:rust && pnpm build:wasm && pnpm test:e2e",
    "dev": "pnpm --filter web dev",
    "install:all": "pnpm install && pnpm run build:wasm"
  },
  "devDependencies": {
    "@playwright/test": "1.46.1"
  }
}