{
  "$schema": "https://primitiv-ui.dev/schema/contract.json",
  "name": "button",
  "version": "0.1.0",
  "root": {
    "element": "button",
    "class": "primitiv-button"
  },
  "dataAttributes": [
    {
      "name": "data-disabled",
      "value": "",
      "when": "disabled",
      "source": "auto"
    }
  ],
  "modifiers": {
    "intent": {
      "primary": "primitiv-button--primary",
      "secondary": "primitiv-button--secondary",
      "danger": "primitiv-button--danger",
      "link": "primitiv-button--link"
    },
    "size": {
      "xs": "primitiv-button--xs",
      "sm": "primitiv-button--sm",
      "md": "primitiv-button--md",
      "lg": "primitiv-button--lg",
      "xl": "primitiv-button--xl"
    }
  },
  "customProperties": [
    { "name": "--primitiv-button-bg", "defaultsTo": "var(--primitiv-action-primary-default)" },
    { "name": "--primitiv-button-fg", "defaultsTo": "var(--primitiv-action-primary-foreground-default)" },
    { "name": "--primitiv-button-border-color", "defaultsTo": "var(--primitiv-action-primary-border-default)" },
    { "name": "--primitiv-button-border-width", "defaultsTo": "var(--primitiv-framed-control-border-width)" },
    { "name": "--primitiv-button-radius", "defaultsTo": "var(--primitiv-framed-control-md-radius)" },
    { "name": "--primitiv-button-height", "defaultsTo": "var(--primitiv-framed-control-md-height)" },
    { "name": "--primitiv-button-padding-inline", "defaultsTo": "var(--primitiv-framed-control-md-padding-inline)" },
    { "name": "--primitiv-button-gap", "defaultsTo": "var(--primitiv-framed-control-md-gap)" },
    { "name": "--primitiv-button-icon-size", "defaultsTo": "var(--primitiv-framed-control-md-icon-size)" },
    { "name": "--primitiv-button-font-family", "defaultsTo": "var(--primitiv-label-md-font-family)" },
    { "name": "--primitiv-button-font-size", "defaultsTo": "var(--primitiv-label-md-font-size)" },
    { "name": "--primitiv-button-font-weight", "defaultsTo": "var(--primitiv-label-md-font-weight)" },
    { "name": "--primitiv-button-line-height", "defaultsTo": "var(--primitiv-label-md-line-height)" }
  ]
}
